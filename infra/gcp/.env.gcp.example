# Daru PDF GCP Environment Variables
# Copy this file to .env.gcp and fill in your values
# NEVER commit .env.gcp to version control

# =============================================================================
# GCP Project Configuration
# =============================================================================

# GCP project ID (required)
GCP_PROJECT_ID=your-project-id

# GCP region for resources
GCP_REGION=asia-northeast1

# Environment (dev, staging, prod)
ENVIRONMENT=dev

# =============================================================================
# Service Account (optional, uses default compute service account if not set)
# =============================================================================

# GCP_SERVICE_ACCOUNT=service-account@your-project-id.iam.gserviceaccount.com

# =============================================================================
# Cloud Storage Buckets
# Bucket names are auto-generated: {project_id}-daru-pdf-{environment}-{type}
# =============================================================================

# GCP_STORAGE_BUCKET_DOCUMENTS=${GCP_PROJECT_ID}-daru-pdf-${ENVIRONMENT}-documents
# GCP_STORAGE_BUCKET_PREVIEWS=${GCP_PROJECT_ID}-daru-pdf-${ENVIRONMENT}-previews
# GCP_STORAGE_BUCKET_CROPS=${GCP_PROJECT_ID}-daru-pdf-${ENVIRONMENT}-crops
# GCP_STORAGE_BUCKET_OUTPUTS=${GCP_PROJECT_ID}-daru-pdf-${ENVIRONMENT}-outputs

# =============================================================================
# Cloud Memorystore (Redis)
# These values are populated after Terraform apply
# =============================================================================

# GCP_REDIS_HOST=10.x.x.x
# GCP_REDIS_PORT=6379

# =============================================================================
# Supabase Configuration (required for database and auth)
# =============================================================================

# Supabase project URL
DARU_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase service role key (NEVER expose in frontend)
DARU_SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase anonymous key (safe for frontend)
DARU_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# OpenAI Configuration (required for LLM features)
# =============================================================================

# OpenAI API key
DARU_OPENAI_API_KEY=sk-...

# OpenAI model (default: gpt-4o-mini)
DARU_OPENAI_MODEL=gpt-4o-mini

# OpenAI timeout in seconds
DARU_OPENAI_TIMEOUT_SECONDS=120

# =============================================================================
# Application Configuration
# =============================================================================

# Debug mode (set to false in production)
DARU_DEBUG=true

# API prefix
DARU_API_PREFIX=/api/v1

# Default confidence threshold for auto-acceptance
DARU_DEFAULT_CONFIDENCE_THRESHOLD=0.7

# Maximum steps per orchestrator run
DARU_MAX_STEPS_PER_RUN=100

# =============================================================================
# Terraform Variables (for Terraform CLI)
# Export these when running terraform commands
# =============================================================================

# export TF_VAR_project_id="$GCP_PROJECT_ID"
# export TF_VAR_region="$GCP_REGION"
# export TF_VAR_environment="$ENVIRONMENT"
# export TF_VAR_supabase_url="$DARU_SUPABASE_URL"
# export TF_VAR_supabase_service_key="$DARU_SUPABASE_SERVICE_KEY"
# export TF_VAR_supabase_anon_key="$DARU_SUPABASE_ANON_KEY"
# export TF_VAR_openai_api_key="$DARU_OPENAI_API_KEY"
