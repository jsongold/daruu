# =============================================================================
# Root Docker Ignore - Daru PDF
# For builds that use root context
# =============================================================================

# Git
.git
.gitignore
.gitattributes

# Claude/AI configuration
.claude/

# Documentation (except essential)
docs/
*.md
!README.md

# IDE
.idea/
.vscode/

# Environment files
.env
.env.*
*.env
.envrc

# OS files
.DS_Store
Thumbs.db

# Python
**/__pycache__/
**/*.py[cod]
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.coverage
**/htmlcov/
**/.venv/
**/venv/

# Node
**/node_modules/
**/dist/
**/build/
**/.eslintcache

# Logs
**/*.log

# Temporary
**/tmp/
**/temp/
**/*.tmp
