{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://daru-pdf.local/schema/template-schema.json",
  "title": "TemplateSchema",
  "type": "object",
  "required": ["version", "name", "fields"],
  "properties": {
    "version": {
      "type": "string",
      "enum": ["v1"]
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/fieldDefinition" }
    }
  },
  "$defs": {
    "validationRule": {
      "type": "object",
      "properties": {
        "min_length": { "type": "integer", "minimum": 0 },
        "max_length": { "type": "integer", "minimum": 0 },
        "regex": { "type": "string" }
      },
      "additionalProperties": false
    },
    "fontPolicy": {
      "type": "object",
      "required": ["size", "min_size"],
      "properties": {
        "family": { "type": "string" },
        "size": { "type": "number", "exclusiveMinimum": 0 },
        "min_size": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": false
    },
    "placement": {
      "type": "object",
      "required": ["page_index", "x", "y", "max_width", "align", "font_policy"],
      "properties": {
        "page_index": { "type": "integer", "minimum": 0 },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "max_width": { "type": "number", "exclusiveMinimum": 0 },
        "align": { "type": "string", "enum": ["left", "center", "right"] },
        "font_policy": { "$ref": "#/$defs/fontPolicy" }
      },
      "additionalProperties": false
    },
    "fieldDefinition": {
      "type": "object",
      "required": ["id", "key", "label", "type", "required", "placement"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "key": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "enum": ["string"] },
        "required": { "type": "boolean" },
        "validation": { "$ref": "#/$defs/validationRule" },
        "placement": { "$ref": "#/$defs/placement" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
