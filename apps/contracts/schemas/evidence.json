{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://daru-pdf.io/schemas/evidence.json",
  "title": "Evidence",
  "description": "Evidence model representing supporting data for extractions",
  "definitions": {
    "BBox": {
      "type": "object",
      "description": "Bounding box coordinates on a page",
      "properties": {
        "page": {
          "type": "integer",
          "minimum": 1,
          "description": "Page number (1-indexed)"
        },
        "x": {
          "type": "number",
          "minimum": 0,
          "description": "X coordinate"
        },
        "y": {
          "type": "number",
          "minimum": 0,
          "description": "Y coordinate"
        },
        "width": {
          "type": "number",
          "minimum": 0,
          "description": "Width of the bounding box"
        },
        "height": {
          "type": "number",
          "minimum": 0,
          "description": "Height of the bounding box"
        }
      },
      "required": ["page", "x", "y", "width", "height"],
      "additionalProperties": false
    },
    "EvidenceSource": {
      "type": "string",
      "enum": ["ocr", "llm", "form_field", "annotation", "manual"],
      "description": "Source of the evidence"
    },
    "Evidence": {
      "type": "object",
      "description": "Evidence supporting an extraction or decision",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier for the evidence"
        },
        "document_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the document this evidence is from"
        },
        "source": {
          "$ref": "#/definitions/EvidenceSource"
        },
        "bbox": {
          "oneOf": [
            { "$ref": "#/definitions/BBox" },
            { "type": "null" }
          ],
          "description": "Bounding box location of the evidence in the document"
        },
        "text": {
          "type": "string",
          "description": "Text content of the evidence"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence score of the evidence"
        },
        "metadata": {
          "type": "object",
          "description": "Additional metadata about the evidence",
          "additionalProperties": true
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the evidence was created"
        }
      },
      "required": ["id", "document_id", "source", "confidence"],
      "additionalProperties": false
    }
  },
  "allOf": [
    { "$ref": "#/definitions/Evidence" }
  ]
}
