{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://daru-pdf.io/schemas/field.json",
  "title": "Field",
  "description": "Field model representing a data field extracted from or to be filled in a document",
  "definitions": {
    "BBox": {
      "type": "object",
      "description": "Bounding box coordinates on a page",
      "properties": {
        "page": {
          "type": "integer",
          "minimum": 1,
          "description": "Page number (1-indexed)"
        },
        "x": {
          "type": "number",
          "minimum": 0,
          "description": "X coordinate (normalized 0-1 or pixels)"
        },
        "y": {
          "type": "number",
          "minimum": 0,
          "description": "Y coordinate (normalized 0-1 or pixels)"
        },
        "width": {
          "type": "number",
          "minimum": 0,
          "description": "Width of the bounding box"
        },
        "height": {
          "type": "number",
          "minimum": 0,
          "description": "Height of the bounding box"
        }
      },
      "required": ["page", "x", "y", "width", "height"],
      "additionalProperties": false
    },
    "FieldType": {
      "type": "string",
      "enum": ["text", "number", "date", "checkbox", "signature", "image"],
      "description": "Type of field value"
    },
    "FieldSource": {
      "type": "string",
      "enum": ["extracted", "manual", "default"],
      "description": "Source of field value"
    },
    "Field": {
      "type": "object",
      "description": "A field in a document with its value and metadata",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier for the field"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable name of the field"
        },
        "type": {
          "$ref": "#/definitions/FieldType"
        },
        "value": {
          "description": "The value of the field (type depends on field type)",
          "oneOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" },
            { "type": "null" }
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence score of the extracted/inferred value"
        },
        "bbox": {
          "oneOf": [
            { "$ref": "#/definitions/BBox" },
            { "type": "null" }
          ],
          "description": "Bounding box location of the field in the document"
        },
        "source": {
          "$ref": "#/definitions/FieldSource"
        },
        "document_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the document this field belongs to"
        },
        "label": {
          "type": "string",
          "description": "Label text associated with this field in the document"
        },
        "required": {
          "type": "boolean",
          "default": false,
          "description": "Whether this field is required"
        },
        "validation_pattern": {
          "type": "string",
          "description": "Regex pattern for validating the field value"
        }
      },
      "required": ["id", "name", "type"],
      "additionalProperties": false
    }
  },
  "allOf": [
    { "$ref": "#/definitions/Field" }
  ]
}
