{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://daru-pdf.io/schemas/activity.json",
  "title": "Activity",
  "description": "Activity model representing an action or event in the system",
  "definitions": {
    "ActivityAction": {
      "type": "string",
      "enum": [
        "job_created",
        "job_started",
        "job_completed",
        "job_failed",
        "job_blocked",
        "document_uploaded",
        "document_processed",
        "field_extracted",
        "field_mapped",
        "field_edited",
        "field_confirmed",
        "value_applied",
        "question_asked",
        "answer_provided",
        "issue_detected",
        "issue_resolved",
        "review_started",
        "output_generated"
      ],
      "description": "Type of activity action"
    },
    "ActivityActor": {
      "type": "string",
      "enum": ["system", "user", "llm", "ocr"],
      "description": "Who or what performed the action"
    },
    "Activity": {
      "type": "object",
      "description": "An activity log entry recording an action in the system",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier for the activity"
        },
        "job_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the job this activity belongs to"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the activity occurred"
        },
        "action": {
          "$ref": "#/definitions/ActivityAction"
        },
        "actor": {
          "$ref": "#/definitions/ActivityActor"
        },
        "details": {
          "type": "object",
          "description": "Additional details about the activity",
          "additionalProperties": true
        },
        "field_id": {
          "type": "string",
          "format": "uuid",
          "description": "Related field ID if applicable"
        },
        "message": {
          "type": "string",
          "description": "Human-readable description of the activity"
        }
      },
      "required": ["id", "job_id", "timestamp", "action", "actor"],
      "additionalProperties": false
    }
  },
  "allOf": [
    { "$ref": "#/definitions/Activity" }
  ]
}
