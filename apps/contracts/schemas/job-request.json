{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://daru-pdf.io/schemas/job-request.json",
  "title": "JobRequest",
  "description": "Job request schemas for creating and running jobs",
  "definitions": {
    "JobCreateRequest": {
      "type": "object",
      "description": "Request to create a new job",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["transfer", "scratch"],
          "description": "Job mode - transfer copies from source to target, scratch fills from scratch"
        },
        "source_document_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of source document (required for transfer mode)"
        },
        "target_document_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of target document to fill"
        },
        "rules": {
          "type": "object",
          "description": "Custom processing rules",
          "additionalProperties": true
        },
        "thresholds": {
          "type": "object",
          "description": "Confidence thresholds",
          "properties": {
            "auto_accept": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "default": 0.9,
              "description": "Threshold for auto-accepting extractions"
            },
            "review_required": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "default": 0.7,
              "description": "Threshold below which review is required"
            }
          },
          "additionalProperties": false
        }
      },
      "required": ["mode", "target_document_id"],
      "additionalProperties": false
    },
    "JobRunRequest": {
      "type": "object",
      "description": "Request to run/execute a job",
      "properties": {
        "run_mode": {
          "type": "string",
          "enum": ["step", "until_blocked", "until_done"],
          "description": "How to execute the job"
        },
        "max_steps": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum number of steps to execute"
        }
      },
      "required": ["run_mode"],
      "additionalProperties": false
    },
    "JobAnswersRequest": {
      "type": "object",
      "description": "Request to submit answers for blocked fields",
      "properties": {
        "answers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/FieldAnswer"
          },
          "minItems": 1,
          "description": "List of field answers"
        }
      },
      "required": ["answers"],
      "additionalProperties": false
    },
    "JobEditsRequest": {
      "type": "object",
      "description": "Request to submit manual edits",
      "properties": {
        "edits": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/FieldEdit"
          },
          "minItems": 1,
          "description": "List of field edits"
        }
      },
      "required": ["edits"],
      "additionalProperties": false
    },
    "FieldAnswer": {
      "type": "object",
      "description": "Answer to a field question",
      "properties": {
        "field_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of field being answered"
        },
        "value": {
          "oneOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" },
            { "type": "null" }
          ],
          "description": "Answer value"
        }
      },
      "required": ["field_id", "value"],
      "additionalProperties": false
    },
    "FieldEdit": {
      "type": "object",
      "description": "Manual edit to a field",
      "properties": {
        "field_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of field being edited"
        },
        "value": {
          "oneOf": [
            { "type": "string" },
            { "type": "number" },
            { "type": "boolean" },
            { "type": "null" }
          ],
          "description": "New value for the field"
        },
        "bbox": {
          "oneOf": [
            { "$ref": "common.json#/definitions/BBox" },
            { "type": "null" }
          ],
          "description": "New bounding box location"
        },
        "render_params": {
          "type": "object",
          "description": "Rendering parameters (font_size, bold, etc.)",
          "additionalProperties": true
        }
      },
      "required": ["field_id"],
      "additionalProperties": false
    }
  },
  "allOf": [
    { "$ref": "#/definitions/JobCreateRequest" }
  ]
}
