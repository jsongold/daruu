{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://daru-pdf.io/schemas/job.json",
  "title": "Job",
  "description": "Job-related schemas for document processing workflows",
  "definitions": {
    "JobMode": {
      "type": "string",
      "enum": ["transfer", "scratch"],
      "description": "Mode of job operation (transfer from source or scratch fill)"
    },
    "JobStatus": {
      "type": "string",
      "enum": ["created", "running", "blocked", "awaiting_input", "done", "failed"],
      "description": "Current status of a job"
    },
    "RunMode": {
      "type": "string",
      "enum": ["step", "until_blocked", "until_done"],
      "description": "Mode for running a job"
    },
    "JobCreate": {
      "type": "object",
      "description": "Request to create a new job",
      "properties": {
        "mode": {
          "$ref": "#/definitions/JobMode"
        },
        "source_document_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of source document (required for transfer mode)"
        },
        "target_document_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of target document"
        },
        "rules": {
          "type": "object",
          "description": "Custom rules for processing",
          "additionalProperties": true
        },
        "thresholds": {
          "type": "object",
          "description": "Confidence thresholds",
          "properties": {
            "auto_accept": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Threshold for auto-accepting extractions"
            },
            "review_required": {
              "type": "number",
              "minimum": 0,
              "maximum": 1,
              "description": "Threshold below which review is required"
            }
          },
          "additionalProperties": true
        }
      },
      "required": ["mode", "target_document_id"],
      "additionalProperties": false
    },
    "JobResponse": {
      "type": "object",
      "description": "Response after job creation",
      "properties": {
        "job_id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique job ID"
        }
      },
      "required": ["job_id"],
      "additionalProperties": false
    },
    "RunRequest": {
      "type": "object",
      "description": "Request to run a job",
      "properties": {
        "run_mode": {
          "$ref": "#/definitions/RunMode"
        },
        "max_steps": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum steps to execute"
        }
      },
      "required": ["run_mode"],
      "additionalProperties": false
    },
    "ConfidenceSummary": {
      "type": "object",
      "description": "Summary of confidence scores across fields",
      "properties": {
        "total_fields": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of fields"
        },
        "high_confidence": {
          "type": "integer",
          "minimum": 0,
          "description": "Fields with confidence >= 0.8"
        },
        "medium_confidence": {
          "type": "integer",
          "minimum": 0,
          "description": "Fields with confidence 0.5-0.8"
        },
        "low_confidence": {
          "type": "integer",
          "minimum": 0,
          "description": "Fields with confidence < 0.5"
        },
        "no_value": {
          "type": "integer",
          "minimum": 0,
          "description": "Fields with no value"
        },
        "average_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Average confidence score"
        }
      },
      "required": ["total_fields", "high_confidence", "medium_confidence", "low_confidence", "no_value", "average_confidence"],
      "additionalProperties": false
    },
    "JobContext": {
      "type": "object",
      "description": "Full context of a job including all state",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique job ID"
        },
        "mode": {
          "$ref": "#/definitions/JobMode"
        },
        "status": {
          "$ref": "#/definitions/JobStatus"
        },
        "source_document": {
          "oneOf": [
            { "$ref": "document.json#/definitions/Document" },
            { "type": "null" }
          ],
          "description": "Source document (null for scratch mode)"
        },
        "target_document": {
          "$ref": "document.json#/definitions/Document",
          "description": "Target document"
        },
        "fields": {
          "type": "array",
          "items": { "$ref": "field.json#/definitions/Field" },
          "description": "All fields"
        },
        "mappings": {
          "type": "array",
          "items": { "$ref": "mapping.json#/definitions/Mapping" },
          "description": "Field mappings"
        },
        "extractions": {
          "type": "array",
          "items": { "$ref": "extraction.json#/definitions/Extraction" },
          "description": "Extracted values"
        },
        "evidence": {
          "type": "array",
          "items": { "$ref": "evidence.json#/definitions/Evidence" },
          "description": "Supporting evidence"
        },
        "issues": {
          "type": "array",
          "items": { "$ref": "issue.json#/definitions/Issue" },
          "description": "Current issues"
        },
        "activities": {
          "type": "array",
          "items": { "$ref": "activity.json#/definitions/Activity" },
          "description": "Activity timeline"
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "Job creation timestamp"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp"
        },
        "progress": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Progress 0-1"
        },
        "current_step": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ],
          "description": "Current processing step"
        },
        "current_stage": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ],
          "description": "Current pipeline stage"
        },
        "next_actions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Available next actions"
        },
        "iteration_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of retry iterations"
        }
      },
      "required": ["id", "mode", "status", "target_document", "created_at", "updated_at"],
      "additionalProperties": false
    },
    "RunResponse": {
      "type": "object",
      "description": "Response after running a job",
      "properties": {
        "status": {
          "$ref": "#/definitions/JobStatus"
        },
        "job_context": {
          "$ref": "#/definitions/JobContext"
        },
        "next_actions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Available next actions"
        }
      },
      "required": ["status", "job_context"],
      "additionalProperties": false
    },
    "FieldAnswer": {
      "type": "object",
      "description": "Answer to a field question",
      "properties": {
        "field_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of field being answered"
        },
        "value": {
          "type": "string",
          "description": "Answer value"
        }
      },
      "required": ["field_id", "value"],
      "additionalProperties": false
    },
    "FieldEdit": {
      "type": "object",
      "description": "Manual edit to a field",
      "properties": {
        "field_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of field being edited"
        },
        "value": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ],
          "description": "New value for the field"
        },
        "bbox": {
          "oneOf": [
            { "$ref": "common.json#/definitions/BBox" },
            { "type": "null" }
          ],
          "description": "New bounding box location"
        },
        "render_params": {
          "type": "object",
          "description": "Rendering parameters",
          "additionalProperties": true
        }
      },
      "required": ["field_id"],
      "additionalProperties": false
    },
    "AnswersRequest": {
      "type": "object",
      "description": "Request to submit answers",
      "properties": {
        "answers": {
          "type": "array",
          "items": { "$ref": "#/definitions/FieldAnswer" },
          "minItems": 1,
          "description": "List of answers"
        }
      },
      "required": ["answers"],
      "additionalProperties": false
    },
    "EditsRequest": {
      "type": "object",
      "description": "Request to submit edits",
      "properties": {
        "edits": {
          "type": "array",
          "items": { "$ref": "#/definitions/FieldEdit" },
          "minItems": 1,
          "description": "List of edits"
        }
      },
      "required": ["edits"],
      "additionalProperties": false
    }
  },
  "allOf": [
    { "$ref": "#/definitions/JobContext" }
  ]
}
