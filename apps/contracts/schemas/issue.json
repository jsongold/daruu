{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://daru-pdf.io/schemas/issue.json",
  "title": "Issue",
  "description": "Issue model representing a problem or warning detected during processing",
  "definitions": {
    "IssueSeverity": {
      "type": "string",
      "enum": ["error", "warning", "info"],
      "description": "Severity level of the issue"
    },
    "IssueType": {
      "type": "string",
      "enum": [
        "missing_value",
        "low_confidence",
        "format_error",
        "validation_error",
        "conflict",
        "ambiguous_mapping",
        "unreadable_content",
        "password_protected",
        "unsupported_format"
      ],
      "description": "Type of issue detected"
    },
    "IssueStatus": {
      "type": "string",
      "enum": ["open", "resolved", "ignored"],
      "description": "Current status of the issue"
    },
    "Issue": {
      "type": "object",
      "description": "An issue detected during document processing",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier for the issue"
        },
        "job_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the job this issue belongs to"
        },
        "field_id": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the related field if applicable"
        },
        "type": {
          "$ref": "#/definitions/IssueType"
        },
        "severity": {
          "$ref": "#/definitions/IssueSeverity"
        },
        "message": {
          "type": "string",
          "description": "Human-readable description of the issue"
        },
        "status": {
          "$ref": "#/definitions/IssueStatus"
        },
        "suggestion": {
          "type": "string",
          "description": "Suggested action to resolve the issue"
        },
        "details": {
          "type": "object",
          "description": "Additional details about the issue",
          "additionalProperties": true
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the issue was detected"
        },
        "resolved_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the issue was resolved"
        }
      },
      "required": ["id", "job_id", "type", "severity", "message"],
      "additionalProperties": false
    }
  },
  "allOf": [
    { "$ref": "#/definitions/Issue" }
  ]
}
