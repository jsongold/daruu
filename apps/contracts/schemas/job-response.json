{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://daru-pdf.io/schemas/job-response.json",
  "title": "JobResponse",
  "description": "Job response schemas for API endpoints",
  "definitions": {
    "JobCreateResponse": {
      "type": "object",
      "description": "Response after creating a job",
      "properties": {
        "success": {
          "type": "boolean",
          "const": true
        },
        "data": {
          "type": "object",
          "properties": {
            "job_id": {
              "type": "string",
              "format": "uuid",
              "description": "Unique job ID"
            }
          },
          "required": ["job_id"],
          "additionalProperties": false
        },
        "meta": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["transfer", "scratch"]
            }
          },
          "additionalProperties": true
        }
      },
      "required": ["success", "data"],
      "additionalProperties": false
    },
    "JobGetResponse": {
      "type": "object",
      "description": "Response for getting job context",
      "properties": {
        "success": {
          "type": "boolean",
          "const": true
        },
        "data": {
          "$ref": "job.json#/definitions/JobContext"
        }
      },
      "required": ["success", "data"],
      "additionalProperties": false
    },
    "JobRunResponse": {
      "type": "object",
      "description": "Response after running a job",
      "properties": {
        "success": {
          "type": "boolean",
          "const": true
        },
        "data": {
          "type": "object",
          "properties": {
            "status": {
              "$ref": "job.json#/definitions/JobStatus"
            },
            "job_context": {
              "$ref": "job.json#/definitions/JobContext"
            },
            "next_actions": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Available next actions"
            }
          },
          "required": ["status", "job_context"],
          "additionalProperties": false
        }
      },
      "required": ["success", "data"],
      "additionalProperties": false
    },
    "JobReviewResponse": {
      "type": "object",
      "description": "Response for job review endpoint",
      "properties": {
        "success": {
          "type": "boolean",
          "const": true
        },
        "data": {
          "type": "object",
          "properties": {
            "issues": {
              "type": "array",
              "items": {
                "$ref": "issue.json#/definitions/Issue"
              }
            },
            "fields": {
              "type": "array",
              "items": {
                "$ref": "field.json#/definitions/Field"
              }
            },
            "confidence_summary": {
              "$ref": "job.json#/definitions/ConfidenceSummary"
            },
            "previews": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "page": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "document_id": {
                    "type": "string",
                    "format": "uuid"
                  },
                  "url": {
                    "type": "string",
                    "format": "uri"
                  },
                  "annotations": {
                    "type": "array",
                    "items": {
                      "$ref": "common.json#/definitions/BBox"
                    }
                  }
                },
                "required": ["page", "url"]
              }
            }
          },
          "required": ["issues", "fields", "confidence_summary"],
          "additionalProperties": false
        }
      },
      "required": ["success", "data"],
      "additionalProperties": false
    },
    "JobActivityResponse": {
      "type": "object",
      "description": "Response for activity log endpoint",
      "properties": {
        "success": {
          "type": "boolean",
          "const": true
        },
        "data": {
          "type": "array",
          "items": {
            "$ref": "activity.json#/definitions/Activity"
          }
        }
      },
      "required": ["success", "data"],
      "additionalProperties": false
    },
    "JobEvidenceResponse": {
      "type": "object",
      "description": "Response for evidence endpoint",
      "properties": {
        "success": {
          "type": "boolean",
          "const": true
        },
        "data": {
          "type": "object",
          "properties": {
            "field_id": {
              "type": "string",
              "format": "uuid"
            },
            "evidence": {
              "type": "array",
              "items": {
                "$ref": "evidence.json#/definitions/Evidence"
              }
            }
          },
          "required": ["field_id", "evidence"],
          "additionalProperties": false
        }
      },
      "required": ["success", "data"],
      "additionalProperties": false
    },
    "JobExportResponse": {
      "type": "object",
      "description": "Response for job export endpoint",
      "properties": {
        "job": {
          "$ref": "job.json#/definitions/JobContext"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "evidence.json#/definitions/Evidence"
          }
        },
        "exported_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["job"],
      "additionalProperties": true
    }
  },
  "allOf": [
    { "$ref": "#/definitions/JobGetResponse" }
  ]
}
