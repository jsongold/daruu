{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://daru-pdf.io/schemas/document.json",
  "title": "Document",
  "description": "Document model representing an uploaded PDF or image file",
  "definitions": {
    "DocumentMeta": {
      "type": "object",
      "description": "Metadata about a document",
      "properties": {
        "page_count": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of pages in the document"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0,
          "description": "File size in bytes"
        },
        "mime_type": {
          "type": "string",
          "pattern": "^[a-z]+/[a-z0-9.+-]+$",
          "description": "MIME type of the document"
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the document was uploaded"
        },
        "filename": {
          "type": "string",
          "description": "Original filename"
        },
        "checksum": {
          "type": "string",
          "description": "SHA-256 checksum of the file"
        }
      },
      "required": ["page_count", "size_bytes", "mime_type", "created_at"],
      "additionalProperties": false
    },
    "Document": {
      "type": "object",
      "description": "A document uploaded to the system",
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique identifier for the document"
        },
        "ref": {
          "type": "string",
          "description": "Reference path or filename for the document"
        },
        "meta": {
          "$ref": "#/definitions/DocumentMeta"
        }
      },
      "required": ["id", "ref", "meta"],
      "additionalProperties": false
    },
    "DocumentUploadRequest": {
      "type": "object",
      "description": "Request body for document upload (multipart form data metadata)",
      "properties": {
        "role": {
          "type": "string",
          "enum": ["source", "target"],
          "description": "Role of the document in the job (source or target)"
        },
        "filename": {
          "type": "string",
          "description": "Original filename"
        }
      },
      "required": ["role"],
      "additionalProperties": false
    },
    "DocumentUploadResponse": {
      "type": "object",
      "description": "Response after successful document upload",
      "properties": {
        "success": {
          "type": "boolean",
          "const": true
        },
        "data": {
          "$ref": "#/definitions/Document"
        }
      },
      "required": ["success", "data"],
      "additionalProperties": false
    },
    "DocumentGetResponse": {
      "type": "object",
      "description": "Response for getting a document by ID",
      "properties": {
        "success": {
          "type": "boolean",
          "const": true
        },
        "data": {
          "$ref": "#/definitions/Document"
        }
      },
      "required": ["success", "data"],
      "additionalProperties": false
    }
  },
  "allOf": [
    { "$ref": "#/definitions/Document" }
  ]
}
