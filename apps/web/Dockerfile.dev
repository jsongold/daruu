# =============================================================================
# Daru PDF Web - Development Dockerfile
# =============================================================================
# Development image with Vite dev server and hot-reload.
#
# Features:
#   - Vite dev server with HMR
#   - Source code mounted as volume
#   - Fast refresh on code changes
#
# Build:
#   docker build -f Dockerfile.dev -t daru-pdf-web:dev .
#
# Run:
#   docker run -p 5173:5173 -v $(pwd)/src:/app/src daru-pdf-web:dev
# =============================================================================

FROM node:20-alpine

# Labels
LABEL maintainer="Daru PDF Team" \
      version="0.1.0-dev" \
      description="Daru PDF Web - Development image"

# Set working directory
WORKDIR /app

# Copy package files
COPY package.json package-lock.json* ./

# Install dependencies
RUN npm ci

# Copy source files
COPY . .

# Expose Vite dev server port
EXPOSE 5173

# Health check (use 127.0.0.1 to avoid IPv6 issues)
HEALTHCHECK --interval=10s --timeout=5s --start-period=30s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://127.0.0.1:5173/ || exit 1

# Start Vite dev server
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
