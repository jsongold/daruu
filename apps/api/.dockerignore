# =============================================================================
# Docker Ignore - Daru PDF API
# Exclude files not needed in Docker builds
# =============================================================================

# Git
.git
.gitignore
.gitattributes

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
.venv/
venv/
ENV/
env/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# IDE and editors
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject

# Environment files (CRITICAL: never include secrets)
.env
.env.*
*.env
.envrc

# Build artifacts
build/
dist/
*.egg-info/
*.egg
wheels/
pip-wheel-metadata/

# Documentation
docs/
*.md
!README.md
LICENSE

# Development files
Makefile
docker-compose*.yml
*.sh

# Test files
tests/
test_*.py
*_test.py
conftest.py

# Temporary files
*.log
*.tmp
*.temp
tmp/
temp/

# OS files
.DS_Store
Thumbs.db

# Poetry
poetry.lock

# Mypy
.mypy_cache/

# Ruff
.ruff_cache/

# Sample/example files
example_*.py
sample_*.py
*.sample

# Output files from development
output.png
response.json
*.pdf
!assets/templates/*.pdf
